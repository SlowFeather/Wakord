# 统一行尾，避免多人/跨平台协作时的 CRLF/LF 噪声
* text=auto eol=lf

*.py    text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.txt   text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf

# 二进制（不做行尾转换）
*.onnx      binary
*.pth       binary
*.tflite    binary
*.npy       binary
*.wav       binary
*.tar.bz2   binary
